[
  {
    "id": "gdsbn-0001",
    "correctOption": "A",
    "difficulty": "easy",
    "sourceYear": 2024,
    "en": {
      "question": "The balanced equation for photosynthesis is:",
      "options": [
        "6CO2 + 6H2O -> C6H12O6 + 6O2",
        "CO2 + H2O -> C6H12O6 + O2",
        "6CO2 + 6O2 -> C6H12O6 + 6H2O",
        "C6H12O6 + 6O2 -> 6CO2 + 6H2O"
      ],
      "explanation": "Photosynthesis: 6CO2 + 6H2O --light/chlorophyll--> C6H12O6 (glucose) + 6O2. It converts light energy into chemical energy."
    },
    "hi": {
      "question": "प्रकाश संश्लेषण का संतुलित समीकरण है:",
      "options": [
        "6CO2 + 6H2O -> C6H12O6 + 6O2",
        "CO2 + H2O -> C6H12O6 + O2",
        "6CO2 + 6O2 -> C6H12O6 + 6H2O",
        "C6H12O6 + 6O2 -> 6CO2 + 6H2O"
      ],
      "explanation": "प्रकाश संश्लेषण: 6CO2 + 6H2O --प्रकाश/क्लोरोफिल--> C6H12O6 (ग्लूकोज) + 6O2। यह प्रकाश ऊर्जा को रासायनिक ऊर्जा में परिवर्तित करता है।"
    }
  },
  {
    "id": "gdsbn-0002",
    "correctOption": "C",
    "difficulty": "easy",
    "sourceYear": 2023,
    "en": {
      "question": "Stomata are tiny pores on leaves that help in:",
      "options": [
        "Absorption of water",
        "Transport of food",
        "Exchange of gases",
        "Growth of plant"
      ],
      "explanation": "Stomata are small openings on the leaf surface, surrounded by guard cells. They allow exchange of gases (CO2 in, O2 out) and transpiration."
    },
    "hi": {
      "question": "रंध्र (स्टोमेटा) पत्तियों पर छोटे छिद्र होते हैं जो किसमें सहायता करते हैं?",
      "options": [
        "जल का अवशोषण",
        "भोजन का परिवहन",
        "गैसों का विनिमय",
        "पादप की वृद्धि"
      ],
      "explanation": "रंध्र पत्ती की सतह पर छोटे छिद्र होते हैं, जो द्वार कोशिकाओं से घिरे होते हैं। ये गैसों के विनिमय (CO2 अंदर, O2 बाहर) और वाष्पोत्सर्जन की अनुमति देते हैं।"
    }
  },
  {
    "id": "gdsbn-0003",
    "correctOption": "C",
    "difficulty": "medium",
    "sourceYear": 2024,
    "en": {
      "question": "Which enzyme breaks down starch in the mouth?",
      "options": [
        "Pepsin",
        "Trypsin",
        "Amylase (ptyalin)",
        "Lipase"
      ],
      "explanation": "Salivary amylase (ptyalin) in saliva breaks down starch into maltose in the mouth. This is the first step of carbohydrate digestion."
    },
    "hi": {
      "question": "मुँह में स्टार्च को कौन सा एंजाइम तोड़ता है?",
      "options": [
        "पेप्सिन",
        "ट्रिप्सिन",
        "एमाइलेज (टायलिन)",
        "लाइपेज"
      ],
      "explanation": "लार में उपस्थित लार एमाइलेज (टायलिन) मुँह में स्टार्च को माल्टोज में तोड़ता है। यह कार्बोहाइड्रेट पाचन का पहला चरण है।"
    }
  },
  {
    "id": "gdsbn-0004",
    "correctOption": "C",
    "difficulty": "medium",
    "sourceYear": 2024,
    "en": {
      "question": "Pepsin, an enzyme in the stomach, digests:",
      "options": [
        "Carbohydrates",
        "Fats",
        "Proteins",
        "Vitamins"
      ],
      "explanation": "Pepsin is a protein-digesting enzyme secreted by the stomach. It works in the acidic medium (HCl) of the stomach to break proteins into peptones."
    },
    "hi": {
      "question": "पेप्सिन, आमाशय में पाया जाने वाला एंजाइम, पाचन करता है:",
      "options": [
        "कार्बोहाइड्रेट का",
        "वसा का",
        "प्रोटीन का",
        "विटामिन का"
      ],
      "explanation": "पेप्सिन आमाशय द्वारा स्रावित प्रोटीन पाचक एंजाइम है। यह आमाशय के अम्लीय माध्यम (HCl) में प्रोटीन को पेप्टोन में तोड़ता है।"
    }
  },
  {
    "id": "gdsbn-0005",
    "correctOption": "C",
    "difficulty": "easy",
    "sourceYear": 2023,
    "en": {
      "question": "Bile is produced by the:",
      "options": [
        "Pancreas",
        "Stomach",
        "Liver",
        "Small intestine"
      ],
      "explanation": "Bile is produced by the liver and stored in the gall bladder. It emulsifies fats, breaking large fat globules into smaller ones for easier digestion."
    },
    "hi": {
      "question": "पित्त रस किसके द्वारा उत्पन्न होता है?",
      "options": [
        "अग्न्याशय",
        "आमाशय",
        "यकृत",
        "छोटी आंत"
      ],
      "explanation": "पित्त रस यकृत द्वारा उत्पन्न होता है और पित्ताशय में संग्रहीत रहता है। यह वसा का पायसीकरण करता है, बड़ी वसा गोलिकाओं को छोटी गोलिकाओं में तोड़ता है जिससे पाचन आसान हो जाता है।"
    }
  },
  {
    "id": "gdsbn-0006",
    "correctOption": "C",
    "difficulty": "medium",
    "sourceYear": 2024,
    "en": {
      "question": "Lipase enzyme digests:",
      "options": [
        "Proteins",
        "Carbohydrates",
        "Fats",
        "Nucleic acids"
      ],
      "explanation": "Lipase breaks down fats (lipids) into fatty acids and glycerol. It is secreted by the pancreas and also present in the small intestine."
    },
    "hi": {
      "question": "लाइपेज एंजाइम पाचन करता है:",
      "options": [
        "प्रोटीन का",
        "कार्बोहाइड्रेट का",
        "वसा का",
        "न्यूक्लिक अम्ल का"
      ],
      "explanation": "लाइपेज वसा (लिपिड) को वसा अम्ल और ग्लिसरॉल में तोड़ता है। यह अग्न्याशय द्वारा स्रावित होता है और छोटी आंत में भी पाया जाता है।"
    }
  },
  {
    "id": "gdsbn-0007",
    "correctOption": "C",
    "difficulty": "easy",
    "sourceYear": 2023,
    "en": {
      "question": "Autotrophic nutrition is found in:",
      "options": [
        "Animals",
        "Fungi",
        "Green plants",
        "Viruses"
      ],
      "explanation": "Green plants are autotrophs — they make their own food through photosynthesis using sunlight, CO2, and water. Animals are heterotrophs."
    },
    "hi": {
      "question": "स्वपोषी पोषण पाया जाता है:",
      "options": [
        "जंतुओं में",
