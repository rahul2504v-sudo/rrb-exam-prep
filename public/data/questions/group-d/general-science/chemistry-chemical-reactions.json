    "hi": {
      "question": "वसा और तेल युक्त खाद्य पदार्थों में बासीपन किसके कारण होता है?",
      "options": [
        "अपचयन",
        "ऑक्सीकरण",
        "जल अपघटन",
        "किण्वन"
      ],
      "explanation": "बासीपन वसा और तेलों का ऑक्सीकरण है जब वे हवा, प्रकाश या नमी के संपर्क में आते हैं। इससे अप्रिय गंध और स्वाद आता है। एंटीऑक्सीडेंट या नाइट्रोजन फ्लशिंग इसे रोकते हैं।"
    }
  },
