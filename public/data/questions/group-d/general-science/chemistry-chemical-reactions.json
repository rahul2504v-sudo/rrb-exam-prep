    "en": {
      "question": "In the reaction Zn + CuSO4 -> ZnSO4 + Cu, what type of reaction is this?",
      "options": [
        "Combination reaction",
        "Decomposition reaction",
        "Displacement reaction",
        "Double displacement reaction"
      ],
      "explanation": "Zinc displaces copper from copper sulphate because zinc is more reactive than copper. This is a single displacement reaction."
    },
    "hi": {
      "question": "अभिक्रिया Zn + CuSO4 -> ZnSO4 + Cu में, यह किस प्रकार की अभिक्रिया है?",
      "options": [
        "संयोजन अभिक्रिया",
        "विघटन अभिक्रिया",
        "विस्थापन अभिक्रिया",
        "द्विविस्थापन अभिक्रिया"
      ],
      "explanation": "जिंक, कॉपर सल्फेट से कॉपर को विस्थापित करता है क्योंकि जिंक कॉपर से अधिक अभिक्रियाशील है। यह एकल विस्थापन अभिक्रिया है।"
    }
  },
