[{"id":"groupd-r-0001","correctOption":"C","difficulty":"easy","sourceYear":2024,"en":{"question":"Find the next term: 2, 6, 12, 20, 30, ?","options":["36","40","42","44"],"explanation":"Pattern: +4, +6, +8, +10, +12. So next = 30 + 12 = 42. Alternatively, n(n+1): 1x2=2, 2x3=6, 3x4=12, 4x5=20, 5x6=30, 6x7=42."},"hi":{"question":"अगला पद ज्ञात करें: 2, 6, 12, 20, 30, ?","options":["36","40","42","44"],"explanation":"पैटर्न: +4, +6, +8, +10, +12। इसलिए अगला = 30 + 12 = 42। वैकल्पिक रूप से, n(n+1): 1×2=2, 2×3=6, 3×4=12, 4×5=20, 5×6=30, 6×7=42।"}},{"id":"groupd-r-0002","correctOption":"C","difficulty":"medium","sourceYear":2023,"en":{"question":"Find the missing term: A, C, F, J, O, ?","options":["S","T","U","V"],"explanation":"Pattern: A(+2)=C, C(+3)=F, F(+4)=J, J(+5)=O, O(+6)=U. So the missing term is U."},"hi":{"question":"लुप्त पद ज्ञात करें: A, C, F, J, O, ?","options":["S","T","U","V"],"explanation":"पैटर्न: A(+2)=C, C(+3)=F, F(+4)=J, J(+5)=O, O(+6)=U। इसलिए लुप्त पद U है।"}},{"id":"groupd-r-0003","correctOption":"D","difficulty":"easy","sourceYear":2024,"en":{"question":"Find the next term: 5, 10, 20, 40, ?","options":["50","60","70","80"],"explanation":"Each term is multiplied by 2: 5x2=10, 10x2=20, 20x2=40, 40x2=80."},"hi":{"question":"अगला पद ज्ञात करें: 5, 10, 20, 40, ?","options":["50","60","70","80"],"explanation":"प्रत्येक पद 2 से गुणा: 5×2=10, 10×2=20, 20×2=40, 40×2=80।"}},{"id":"groupd-r-0004","correctOption":"C","difficulty":"easy","sourceYear":2023,"en":{"question":"Find the missing term: 1, 4, 9, 16, ?, 36","options":["20","24","25","28"],"explanation":"These are perfect squares: 1^2, 2^2, 3^2, 4^2, 5^2=25, 6^2."},"hi":{"question":"लुप्त पद ज्ञात करें: 1, 4, 9, 16, ?, 36","options":["20","24","25","28"],"explanation":"ये पूर्ण वर्ग हैं: 1^2, 2^2, 3^2, 4^2, 5^2=25, 6^2।"}},{"id":"groupd-r-0005","correctOption":"D","difficulty":"medium","sourceYear":2024,"en":{"question":"Find the wrong term: 3, 8, 15, 24, 34, 48","options":["8","15","24","34"],"explana