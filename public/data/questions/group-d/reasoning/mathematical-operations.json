[{"id":"groupd-r-0001","correctOption":"B","difficulty":"medium","sourceYear":2024,"en":{"question":"If + means x, - means /, x means -, and / means +, then what is 12 + 4 - 2 x 6 / 8?","options":["24","26","28","30"],"explanation":"After substitution: 12 x 4 / 2 - 6 + 8. BODMAS: 12x4=48, 48/2=24, 24-6=18, 18+8=26."},"hi":{"question":"यदि + का अर्थ ×, - का अर्थ ÷, × का अर्थ -, और ÷ का अर्थ + है, तो 12 + 4 - 2 × 6 ÷ 8 का मान?","options":["24","26","28","30"],"explanation":"प्रतिस्थापन: 12×4÷2-6+8। BODMAS: 12×4=48, 48÷2=24, 24-6=18, 18+8=26।"}},{"id":"groupd-r-0002","correctOption":"C","difficulty":"easy","sourceYear":2023,"en":{"question":"If 16 * 4 = 64 and 25 * 3 = 75, then 18 * 5 = ?","options":["80","85","90","95"],"explanation":"The * operation means multiplication: 16x4=64, 25x3=75, 18x5=90."},"hi":{"question":"यदि 16 * 4 = 64 और 25 * 3 = 75, तो 18 * 5 = ?","options":["80","85","90","95"],"explanation":"* का अर्थ गुणा: 16×4=64, 25×3=75, 18×5=90।"}},{"id":"groupd-r-0003","correctOption":"B","difficulty":"medium","sourceYear":2024,"en":{"question":"If + means -, - means x, x means /, and / means +, then 15 + 3 - 2 x 6 / 2 = ?","options":["14","16","18","20"],"explanation":"After substitution: 15 - 3 x 2 / 6 + 2. BODMAS: 3x2=6, 6/6=1, 15-1+2=16."},"hi":{"question":"यदि + का अर्थ -, - का अर्थ ×, × का अर्थ ÷, ÷ का अर्थ +, तो 15 + 3 - 2 × 6 ÷ 2 = ?","options":["14","16","18","20"],"explanation":"प्रतिस्थापन: 15-3×2÷6+2। BODMAS: 3×2=6, 6÷6=1, 15-1+2=16।"}},{"id":"groupd-r-0004","correctOption":"C","difficulty":"easy","sourceYear":2023,"en":{"question":"If 8 * 3 = 24 and 7 * 5 = 35, then 9 * 6 = ?","options":["45","48","54","56"],"explanation":"The * operation means multiplication: 8x3=24, 7x5=35, 9x6=54."},"hi":{"question":"यदि 8 * 3 = 24 और 7 * 5 = 35, तो 9 * 6 = ?","options":["45","48","54","56"],"explanation":"* का अर्थ गुणा: 8×3=24, 7×5=35, 9×6=54।"}},{"id":"groupd-r-0005","correctOption":"A","difficulty":"medium","sourceYear":2024,"en":{"question":"If 5 # 3 = 16, 7 # 2 = 18, then 6 # 4 = ?","options":["20","22","24","26"],"explanation":"Pattern: a # b = (a + b) x 2. 5+3=8, 8x2=16. 7+2=9, 9x2=18. 6+4=10, 10x2=20."},"hi":{"question":"यदि 5 # 3 = 16, 7 # 2 = 18, तो 6 # 4 = ?","options":["20","22","24","26"],"explanation":"पैटर्न: a # b = (a+b)×2। 5+3=8, 8×2=16। 7+2=9, 9×2=18। 6+4=10, 10×2=20।"}},{"id":"groupd-r-0006","correctOption":"C","difficulty":"easy","sourceYear":2023,"en":{"question":"If 4 $ 2 = 8 and 5 $ 3 = 15, then 7 $ 4 = ?","options":["24","26","28","30"],"explanation":"Pattern: $ means multiplication. 4x2=8, 5x3=15, 7x4=28."},"hi":{"question":"यदि 4 $ 2 = 8 और 5 $ 3 = 15, तो 7 $ 4 = ?","options":["24","26","28","30"],"explanation":"$ का अर्थ गुणा: 4×2=8, 5×3=15, 7×4=28।"}},{"id":"groupd-r-0007","correctOption":"C","difficulty":"medium","sourceYear":2024,"en":{"question":"If P means +, Q means -, R means x, S means /, then 18 R 3 S 6 P 4 Q 2 = ?","options":["9","10","11","12"],"explanation":"18 x 3 / 6 + 4 - 2. BODMAS: 18x3=54, 54/6=9, 9+4=13, 13-2=11."},"hi":{"question":"यदि P का अर्थ +, Q का अर्थ -, R का अर्थ ×, S का अर्थ ÷, तो 18 R 3 S 6 P 4 Q 2 = ?","options":["9","10","11","12"],"explanation":"18×3÷6+4-2। BODMAS: 18×3=54, 54÷6=9, 9+4=13, 13-2=11।"}},{"id":"groupd-r-0008","correctOption":"C","difficulty":"medium","sourceYear":2023,"en":{"question":"If 3 @ 4 = 25 and 5 @ 6 = 61, then 2 @ 8 = ?","options":["64","66","68","70"],"explanation":"Pattern: a @ b = a^2 + b^2. 3^2+4^2=25. 5^2+6^2=61. 2^2+8^2=68."},"hi":{"question":"यदि 3 @ 4 = 25 और 5 @ 6 = 61, तो 2 @ 8 = ?","options":["64","66","68","70"],"explanation":"पैटर्न: a @ b = a^2 + b^2। 3^2+4^2=25। 5^2+6^2=61। 2^2+8^2=68।"}}]
