  {
    "id": "gdmpl-0003",
    "correctOption": "D",
    "difficulty": "medium",
    "sourceYear": 2024,
    "en": {
      "question": "A fruit seller bought oranges at 6 for Rs. 10 and sold them at 4 for Rs. 10. Find his profit percentage.",
      "options": [
        "25%",
        "33.33%",
        "40%",
        "50%"
      ],
      "explanation": "CP per orange = 10/6 = Rs. 1.67, SP per orange = 10/4 = Rs. 2.50. Profit = 2.50 - 1.67 = 0.83. Profit % = (0.83/1.67) x 100 = 50%."
    },
    "hi": {
      "question": "एक फल विक्रेता ने 6 संतरे Rs. 10 में खरीदे और 4 संतरे Rs. 10 में बेचे। उसका लाभ प्रतिशत ज्ञात करें।",
      "options": [
        "25%",
        "33.33%",
        "40%",
        "50%"
      ],
      "explanation": "प्रति संतरा क्रय मूल्य = 10/6 = Rs. 1.67, प्रति संतरा विक्रय मूल्य = 10/4 = Rs. 2.50। लाभ = 2.50 - 1.67 = 0.83। लाभ % = (0.83/1.67) × 100 = 50%।"
    }
  },
