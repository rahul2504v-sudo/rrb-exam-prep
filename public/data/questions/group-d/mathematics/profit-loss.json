    "sourceYear": 2023,
    "en": {
      "question": "A shopkeeper sold two watches at Rs. 720 each. On one he gained 20% and on the other he lost 20%. What is his overall gain or loss percentage?",
      "options": [
        "No gain no loss",
        "2% loss",
        "4% loss",
        "4% gain"
      ],
      "explanation": "When two articles are sold at same SP with equal % gain and loss, overall loss % = (x^2)/100 = 20^2/100 = 4% loss."
    },
    "hi": {
      "question": "एक दुकानदार ने दो घड़ियां Rs. 720 प्रति घड़ी बेचीं। एक पर उसे 20% लाभ और दूसरी पर 20% हानि हुई। कुल लाभ या हानि प्रतिशत क्या है?",
      "options": [
        "न लाभ न हानि",
        "2% हानि",
        "4% हानि",
        "4% लाभ"
      ],
      "explanation": "जब दो वस्तुएं समान विक्रय मूल्य पर समान % लाभ और हानि के साथ बेची जाती हैं, तो कुल हानि % = (x^2)/100 = 20^2/100 = 4% हानि।"
    }
  },
