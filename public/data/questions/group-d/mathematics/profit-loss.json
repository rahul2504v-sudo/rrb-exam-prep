  {
    "id": "gdmpl-0005",
    "correctOption": "B",
    "difficulty": "medium",
    "sourceYear": 2023,
    "en": {
      "question": "A shopkeeper offers a discount of 20% on the marked price and still makes a profit of 12%. If the cost price is Rs. 500, what is the marked price?",
      "options": [
        "Rs. 650",
        "Rs. 700",
        "Rs. 720",
        "Rs. 750"
      ],
      "explanation": "SP = 500 x 1.12 = 560. After 20% discount, SP = 0.8 x MP. So MP = 560/0.8 = 700."
    },
    "hi": {
      "question": "एक दुकानदार अंकित मूल्य पर 20% की छूट देता है और फिर भी 12% का लाभ कमाता है। यदि क्रय मूल्य Rs. 500 है, तो अंकित मूल्य क्या है?",
      "options": [
        "Rs. 650",
        "Rs. 700",
        "Rs. 720",
        "Rs. 750"
      ],
      "explanation": "विक्रय मूल्य = 500 × 1.12 = 560। 20% छूट के बाद, विक्रय मूल्य = 0.8 × अंकित मूल्य। इसलिए अंकित मूल्य = 560/0.8 = 700।"
    }
  },
  {
    "id": "gdmpl-0006",
    "correctOption": "C",
    "difficulty": "medium",
    "sourceYear": 2024,
    "en": {
      "question": "A person sells an article at 20% profit. Had he bought it at 20% less and sold it for Rs. 75 less, he would have gained 25%. Find the cost price.",
      "options": [
        "Rs. 300",
        "Rs. 350",
        "Rs. 375",
        "Rs. 400"
      ],
      "explanation": "Let CP = x. Original SP = 1.2x. New CP = 0.8x. New SP = 1.2x - 75. For 25% profit on new CP: new SP = 1.25 x 0.8x = x. So 1.2x - 75 = x. 0.2x = 75, x = 375."
    },
    "hi": {
      "question": "एक व्यक्ति 20% लाभ पर एक वस्तु बेचता है। यदि वह इसे 20% कम में खरीदता और Rs. 75 कम में बेचता, तो उसे 25% का लाभ होता। क्रय मूल्य ज्ञात करें।",
      "options": [
        "Rs. 300",
        "Rs. 350",
        "Rs. 375",
        "Rs. 400"
      ],
      "explanation": "माना क्रय मूल्य = x। मूल विक्रय मूल्य = 1.2x। नया क्रय मूल्य = 0.8x। नया विक्रय मूल्य = 1.2x - 75। नए क्रय मूल्य पर 25% लाभ: नया विक्रय मूल्य = 1.25 × 0.8x = x। इसलिए 1.2x - 75 = x। 0.2x = 75, x = 375।"
    }
  },
