    "en": {
      "question": "A shopkeeper buys a product for Rs. 500 and sells it for Rs. 600. What is the profit percentage?",
      "options": [
        "10%",
        "15%",
        "20%",
        "25%"
      ],
      "explanation": "Profit = 600 - 500 = 100. Profit % = (100/500) x 100 = 20%."
    },
    "hi": {
      "question": "एक दुकानदार Rs. 500 में एक वस्तु खरीदता है और Rs. 600 में बेचता है। लाभ प्रतिशत क्या है?",
      "options": [
        "10%",
        "15%",
        "20%",
        "25%"
      ],
      "explanation": "लाभ = 600 - 500 = 100। लाभ % = (100/500) × 100 = 20%।"
    }
  },
