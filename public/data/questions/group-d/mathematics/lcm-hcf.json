    "en": {
      "question": "Three bells ring at intervals of 12, 15, and 18 minutes. If they ring together at 10:00 AM, when will they next ring together?",
      "options": [
        "10:30 AM",
        "11:00 AM",
        "1:00 PM",
        "1:30 PM"
      ],
      "explanation": "LCM of 12, 15, 18 = 180 minutes = 3 hours. 10:00 AM + 3 hrs = 1:00 PM."
    },
    "hi": {
      "question": "तीन घंटियां 12, 15 और 18 मिनट के अंतराल पर बजती हैं। यदि वे सुबह 10:00 बजे एक साथ बजती हैं, तो अगली बार एक साथ कब बजेंगी?",
      "options": [
        "सुबह 10:30",
        "सुबह 11:00",
        "दोपहर 1:00",
        "दोपहर 1:30"
      ],
      "explanation": "12, 15, 18 का LCM = 180 मिनट = 3 घंटे। सुबह 10:00 + 3 घंटे = दोपहर 1:00।"
    }
