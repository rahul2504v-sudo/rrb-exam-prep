      "options": [
        "15 वर्ष",
        "20 वर्ष",
        "25 वर्ष",
        "30 वर्ष"
      ],
      "explanation": "3x + 5x = 40। 8x = 40, x = 5। B = 5x = 25 वर्ष।"
    }
