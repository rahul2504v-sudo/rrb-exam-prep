  {
    "id": "gdmap-0003",
    "correctOption": "B",
    "difficulty": "medium",
    "sourceYear": 2024,
    "en": {
      "question": "Five years ago, the ratio of ages of A and B was 3 : 4. After 5 years, the ratio will be 5 : 6. Find A's present age.",
      "options": [
        "15 years",
        "20 years",
        "25 years",
        "30 years"
      ],
      "explanation": "Let ages 5 yrs ago: A=3x, B=4x. After 5 yrs: A=3x+10, B=4x+10. Ratio: (3x+10)/(4x+10)=5/6. 18x+60=20x+50. 2x=10, x=5. Present A = 3x+5 = 20."
    },
    "hi": {
      "question": "पांच वर्ष पहले, A और B की आयु का अनुपात 3 : 4 था। 5 वर्ष बाद, अनुपात 5 : 6 होगा। A की वर्तमान आयु ज्ञात करें।",
      "options": [
        "15 वर्ष",
        "20 वर्ष",
        "25 वर्ष",
        "30 वर्ष"
      ],
      "explanation": "माना 5 वर्ष पहले: A=3x, B=4x। 5 वर्ष बाद: A=3x+10, B=4x+10। अनुपात: (3x+10)/(4x+10)=5/6। 18x+60=20x+50। 2x=10, x=5। वर्तमान A = 3x+5 = 20।"
    }
  },
  {
    "id": "gdmap-0004",
    "correctOption": "B",
    "difficulty": "easy",
    "sourceYear": 2023,
    "en": {
      "question": "A father is 4 times as old as his son. After 16 years, he will be twice as old. Find the son's present age.",
      "options": [
        "6 years",
        "8 years",
        "10 years",
        "12 years"
      ],
      "explanation": "Son = x, father = 4x. After 16 yrs: 4x+16 = 2(x+16). 4x+16 = 2x+32. 2x = 16, x = 8."
    },
    "hi": {
      "question": "एक पिता अपने पुत्र की आयु का 4 गुना है। 16 वर्ष बाद, वह दोगुना होगा। पुत्र की वर्तमान आयु ज्ञात करें।",
      "options": [
        "6 वर्ष",
        "8 वर्ष",
        "10 वर्ष",
        "12 वर्ष"
      ],
      "explanation": "पुत्र = x, पिता = 4x। 16 वर्ष बाद: 4x+16 = 2(x+16)। 4x+16 = 2x+32। 2x = 16, x = 8।"
    }
  },
  {
    "id": "gdmap-0005",
    "correctOption": "C",
    "difficulty": "medium",
    "sourceYear": 2024,
    "en": {
      "question": "The sum of present ages of A, B, and C is 93 years. Five years ago, their ages were in the ratio 3 : 4 : 5. Find A's present age.",
      "options": [
        "20 years",
        "22 years",
        "24 years",
        "26 years"
      ],
      "explanation": "Sum 5 yrs ago = 93 - 15 = 78. Ratio sum = 3+4+5 = 12. One part = 78/12 = 6.5. A 5 yrs ago = 3 x 6.5 = 19.5. A present = 19.5 + 5 = 24.5. Nearest = 24 years."
    },
    "hi": {
      "question": "A, B और C की वर्तमान आयु का योग 93 वर्ष है। पांच वर्ष पहले, उनकी आयु का अनुपात 3 : 4 : 5 था। A की वर्तमान आयु ज्ञात करें।",
      "options": [
        "20 वर्ष",
        "22 वर्ष",
        "24 वर्ष",
        "26 वर्ष"
      ],
      "explanation": "5 वर्ष पहले का योग = 93 - 15 = 78। अनुपात योग = 3+4+5 = 12। एक भाग = 78/12 = 6.5। A 5 वर्ष पहले = 3 × 6.5 = 19.5। A वर्तमान = 19.5 + 5 = 24.5। निकटतम = 24 वर्ष।"
    }
  },
