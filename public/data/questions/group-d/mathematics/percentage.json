    "difficulty": "medium",
    "sourceYear": 2023,
    "en": {
      "question": "If a number is increased by 20% and then decreased by 20%, what is the net change?",
      "options": [
        "No change",
        "4% increase",
        "4% decrease",
        "2% decrease"
      ],
      "explanation": "Successive change = a + b + ab/100 = 20 + (-20) + (20 x -20)/100 = 0 - 4 = -4%. Net 4% decrease."
    },
    "hi": {
      "question": "यदि किसी संख्या को 20% बढ़ाया जाए और फिर 20% घटाया जाए, तो शुद्ध परिवर्तन क्या है?",
      "options": [
        "कोई परिवर्तन नहीं",
        "4% वृद्धि",
        "4% कमी",
        "2% कमी"
      ],
      "explanation": "क्रमिक परिवर्तन = a + b + ab/100 = 20 + (-20) + (20 × -20)/100 = 0 - 4 = -4%। शुद्ध 4% कमी।"
    }
  },
