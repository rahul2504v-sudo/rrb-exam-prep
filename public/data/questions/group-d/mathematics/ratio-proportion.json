    "en": {
      "question": "If 20 men can build a wall in 9 days, how many men are needed to build the same wall in 12 days?",
      "options": [
        "12",
        "15",
        "18",
        "24"
      ],
      "explanation": "M1 x D1 = M2 x D2. 20 x 9 = M2 x 12. M2 = 180/12 = 15 men."
    },
    "hi": {
      "question": "यदि 20 आदमी 9 दिन में एक दीवार बना सकते हैं, तो 12 दिन में वही दीवार बनाने के लिए कितने आदमी चाहिए?",
      "options": [
        "12",
        "15",
        "18",
        "24"
      ],
      "explanation": "M1 × D1 = M2 × D2। 20 × 9 = M2 × 12। M2 = 180/12 = 15 आदमी।"
    }
  },
