    "hi": {
      "question": "80 लीटर के मिश्रण में दूध और पानी का अनुपात 7 : 3 है। कितना पानी मिलाया जाए कि अनुपात 7 : 5 हो जाए?",
      "options": [
        "12 L",
        "16 L",
        "20 L",
        "24 L"
      ],
      "explanation": "दूध = 7/10 × 80 = 56 L, पानी = 24 L। नया अनुपात: 56/(24+x) = 7/5। 280 = 168 + 7x। 7x = 112, x = 16 L।"
    }
