[{"id":"groupd-m-0001","correctOption":"C","difficulty":"easy","sourceYear":2024,"en":{"question":"If x + 5 = 12, what is the value of x?","options":["5","6","7","8"],"explanation":"x = 12 - 5 = 7."},"hi":{"question":"यदि x + 5 = 12 हो, तो x का मान क्या है?","options":["5","6","7","8"],"explanation":"x = 12 - 5 = 7।"}},{"id":"groupd-m-0002","correctOption":"C","difficulty":"easy","sourceYear":2023,"en":{"question":"If a + b = 10 and a - b = 4, find the value of a.","options":["5","6","7","8"],"explanation":"Adding: (a+b) + (a-b) = 10 + 4, so 2a = 14, a = 7."},"hi":{"question":"यदि a + b = 10 और a - b = 4 हो, तो a का मान ज्ञात करें।","options":["5","6","7","8"],"explanation":"जोड़ने पर: (a+b) + (a-b) = 10 + 4, इसलिए 2a = 14, a = 7।"}},{"id":"groupd-m-0003","correctOption":"C","difficulty":"easy","sourceYear":2024,"en":{"question":"Solve for x: 3x - 7 = 2x + 8","options":["5","10","15","20"],"explanation":"3x - 2x = 8 + 7. x = 15."},"hi":{"question":"x के लिए हल करें: 3x - 7 = 2x + 8","options":["5","10","15","20"],"explanation":"3x - 2x = 8 + 7। x = 15।"}},{"id":"groupd-m-0004","correctOption":"B","difficulty":"medium","sourceYear":2023,"en":{"question":"If x + y = 14 and xy = 48, find the value of x^2 + y^2.","options":["80","100","120","140"],"explanation":"x^2 + y^2 = (x+y)^2 - 2xy = 196 - 96 = 100."},"hi":{"question":"यदि x + y = 14 और xy = 48 हो, तो x^2 + y^2 का मान ज्ञात करें।","options":["80","100","120","140"],"explanation":"x^2 + y^2 = (x+y)^2 - 2xy = 196 - 96 = 100।"}},{"id":"groupd-m-0005","correctOption":"C","difficulty":"easy","sourceYear":2024,"en":{"question":"Find the value of: (a+b)^2 - (a-b)^2","options":["2ab","2(a^2+b^2)","4ab","a^2 + b^2"],"explanation":"(a+b)^2 - (a-b)^2 = (a^2+2ab+b^2) - (a^2-2ab+b^2) = 4ab."},"hi":{"question":"मान ज्ञात करें: (a+b)^2 - (a-b)^2","options":["2ab","2(a^2+b^2)","4ab","a^2 + b^2"],"explanation":"(a+b)^2 - (a-b)^2 = (a^2+2ab+b^2) - (a^2-2ab+b^2) = 4ab।"}},{"id":"groupd-m-0006","correctOption":"B","difficulty":"easy"