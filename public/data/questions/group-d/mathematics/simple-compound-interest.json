      "options": [
        "Rs. 2000",
        "Rs. 2050",
        "Rs. 2100",
        "Rs. 2150"
      ],
      "explanation": "मिश्रधन = 10000 × (1.1)^2 = 10000 × 1.21 = 12100। चक्रवृद्धि ब्याज = 12100 - 10000 = 2100।"
    }
  },
  {
    "id": "gdmsci-0003",
    "correctOption": "C",
    "difficulty": "easy",
    "sourceYear": 2024,
    "en": {
      "question": "A sum of money doubles itself in 10 years at simple interest. What is the rate of interest?",
      "options": [
        "5%",
        "8%",
        "10%",
        "12%"
      ],
      "explanation": "SI = P when amount doubles. P = P x R x 10 / 100. R = 100/10 = 10%."
    },
    "hi": {
      "question": "एक धनराशि साधारण ब्याज पर 10 वर्षों में दोगुनी हो जाती है। ब्याज दर क्या है?",
      "options": [
        "5%",
        "8%",
        "10%",
        "12%"
      ],
      "explanation": "जब राशि दोगुनी होती है, साधारण ब्याज = P। P = P × R × 10 / 100। R = 100/10 = 10%।"
    }
  },
  {
    "id": "gdmsci-0004",
    "correctOption": "B",
    "difficulty": "medium",
    "sourceYear": 2023,
    "en": {
      "question": "At what rate of compound interest will Rs. 5000 amount to Rs. 6050 in 2 years?",
      "options": [
        "8%",
        "10%",
        "12%",
        "15%"
      ],
      "explanation": "6050/5000 = 1.21 = (1+R/100)^2. 1+R/100 = sqrt(1.21) = 1.1. R = 10%."
    },
    "hi": {
      "question": "किस चक्रवृद्धि ब्याज दर पर Rs. 5000, 2 वर्षों में Rs. 6050 हो जाएगा?",
      "options": [
        "8%",
        "10%",
        "12%",
        "15%"
      ],
      "explanation": "6050/5000 = 1.21 = (1+R/100)^2। 1+R/100 = √(1.21) = 1.1। R = 10%।"
    }
  },
