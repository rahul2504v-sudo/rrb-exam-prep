  {
    "id": "gdmsci-0006",
    "correctOption": "B",
    "difficulty": "easy",
    "sourceYear": 2023,
    "en": {
      "question": "Rs. 8000 is invested at 10% compound interest compounded annually. What is the approximate amount after 1 year 4 months?",
      "options": [
        "Rs. 9080",
        "Rs. 9120",
        "Rs. 9160",
        "Rs. 9200"
      ],
      "explanation": "After 1 year: 8000 x 1.10 = 8800. For remaining 4 months: SI on 8800 = 8800 x 10 x (1/3) / 100 = 293.33. Total = 8800 + 293.33 = 9093.33. Approximately Rs. 9120."
    },
    "hi": {
      "question": "Rs. 8000 का 10% वार्षिक चक्रवृद्धि ब्याज पर निवेश किया जाता है। 1 वर्ष 4 माह बाद लगभग मिश्रधन क्या होगा?",
      "options": [
        "Rs. 9080",
        "Rs. 9120",
        "Rs. 9160",
        "Rs. 9200"
      ],
      "explanation": "1 वर्ष बाद: 8000 × 1.10 = 8800। शेष 4 माह (1/3 वर्ष) के लिए: 8800 पर साधारण ब्याज = 8800 × 10 × (1/3) / 100 = 293.33। कुल = 8800 + 293.33 = 9093.33। लगभग Rs. 9120।"
    }
  },
  {
    "id": "gdmsci-0007",
    "correctOption": "B",
    "difficulty": "easy",
    "sourceYear": 2024,
    "en": {
      "question": "In how many years will Rs. 1500 amount to Rs. 1800 at 5% simple interest?",
      "options": [
        "3 years",
        "4 years",
        "5 years",
        "6 years"
      ],
      "explanation": "SI = 1800 - 1500 = 300. 300 = 1500 x 5 x T / 100. T = 300 x 100 / (1500 x 5) = 4 years."
    },
    "hi": {
      "question": "5% साधारण ब्याज पर Rs. 1500 कितने वर्षों में Rs. 1800 हो जाएगा?",
      "options": [
        "3 वर्ष",
        "4 वर्ष",
        "5 वर्ष",
        "6 वर्ष"
      ],
      "explanation": "साधारण ब्याज = 1800 - 1500 = 300। 300 = 1500 × 5 × T / 100। T = 300 × 100 / (1500 × 5) = 4 वर्ष।"
    }
  },
