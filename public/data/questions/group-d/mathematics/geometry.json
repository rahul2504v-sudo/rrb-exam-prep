    "en": {
      "question": "In a triangle, if two angles are 40 degrees and 60 degrees, what is the third angle?",
      "options": [
        "60 degrees",
        "70 degrees",
        "80 degrees",
        "90 degrees"
      ],
      "explanation": "Sum of angles in a triangle = 180 degrees. Third angle = 180 - 40 - 60 = 80 degrees."
    },
    "hi": {
      "question": "एक त्रिभुज में, यदि दो कोण 40 डिग्री और 60 डिग्री हैं, तो तीसरा कोण क्या है?",
      "options": [
        "60 डिग्री",
        "70 डिग्री",
        "80 डिग्री",
        "90 डिग्री"
      ],
      "explanation": "त्रिभुज के कोणों का योग = 180 डिग्री। तीसरा कोण = 180 - 40 - 60 = 80 डिग्री।"
    }
  },
  {
