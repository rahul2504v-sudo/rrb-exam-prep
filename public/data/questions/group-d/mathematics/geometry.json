    "sourceYear": 2023,
    "en": {
      "question": "The diagonals of a rhombus are 8 cm and 6 cm. Find its area.",
      "options": [
        "20 sq cm",
        "24 sq cm",
        "28 sq cm",
        "48 sq cm"
      ],
      "explanation": "Area of rhombus = (d1 x d2) / 2 = (8 x 6) / 2 = 48 / 2 = 24 sq cm."
    },
    "hi": {
      "question": "एक समचतुर्भुज के विकर्ण 8 cm और 6 cm हैं। इसका क्षेत्रफल ज्ञात करें।",
      "options": [
        "20 वर्ग cm",
        "24 वर्ग cm",
        "28 वर्ग cm",
        "48 वर्ग cm"
      ],
      "explanation": "समचतुर्भुज का क्षेत्रफल = (d1 × d2) / 2 = (8 × 6) / 2 = 48 / 2 = 24 वर्ग cm।"
    }
  },
  {
    "id": "groupd-m-0003",
    "correctOption": "B",
    "difficulty": "easy",
    "sourceYear": 2024,
    "en": {
      "question": "In a right-angled triangle, the two legs are 5 cm and 12 cm. Find the hypotenuse.",
      "options": [
        "11 cm",
        "13 cm",
        "15 cm",
        "17 cm"
      ],
      "explanation": "Hypotenuse = sqrt(5^2 + 12^2) = sqrt(25+144) = sqrt(169) = 13 cm."
    },
    "hi": {
      "question": "एक समकोण त्रिभुज में, दो भुजाएं 5 cm और 12 cm हैं। कर्ण ज्ञात करें।",
      "options": [
        "11 cm",
        "13 cm",
        "15 cm",
        "17 cm"
      ],
      "explanation": "कर्ण = √(5^2 + 12^2) = √(25+144) = √(169) = 13 cm।"
    }
  },
  {
    "id": "groupd-m-0004",
    "correctOption": "C",
    "difficulty": "easy",
    "sourceYear": 2023,
    "en": {
      "question": "The ratio of the radii of two circles is 2 : 3. What is the ratio of their areas?",
      "options": [
        "2 : 3",
        "3 : 2",
        "4 : 9",
        "9 : 4"
      ],
      "explanation": "Area ratio = (radius ratio)^2 = (2/3)^2 = 4 : 9."
    },
    "hi": {
      "question": "दो वृत्तों की त्रिज्याओं का अनुपात 2 : 3 है। उनके क्षेत्रफलों का अनुपात क्या है?",
      "options": [
        "2 : 3",
        "3 : 2",
        "4 : 9",
        "9 : 4"
      ],
      "explanation": "क्षेत्रफल अनुपात = (त्रिज्या अनुपात)^2 = (2/3)^2 = 4 : 9।"
    }
  },
  {
    "id": "groupd-m-0005",
    "correctOption": "B",
    "difficulty": "medium",
    "sourceYear": 2024,
    "en": {
      "question": "A chord of length 16 cm is at a distance of 6 cm from the center of a circle. Find the radius of the circle.",
      "options": [
        "8 cm",
        "10 cm",
        "12 cm",
        "14 cm"
      ],
      "explanation": "Radius = sqrt((chord/2)^2 + distance^2) = sqrt(8^2 + 6^2) = sqrt(64+36) = sqrt(100) = 10 cm."
    },
    "hi": {
      "question": "16 cm लंबी एक जीवा वृत्त के केंद्र से 6 cm की दूरी पर है। वृत्त की त्रिज्या ज्ञात करें।",
      "options": [
        "8 cm",
        "10 cm",
        "12 cm",
        "14 cm"
      ],
      "explanation": "त्रिज्या = √((जीवा/2)^2 + दूरी^2) = √(8^2 + 6^2) = √(64+36) = √(100) = 10 cm।"
    }
  },
  {
    "id": "groupd-m-0006",
    "correctOption": "C",
    "difficulty": "medium",
    "sourceYear": 2023,
    "en": {
      "question": "The perimeter of a square is equal to the circumference of a circle. If the side of the square is 11 cm, find the radius of the circle. (Use pi = 22/7)",
      "options": [
        "5 cm",
        "6 cm",
        "7 cm",
        "8 cm"
      ],
      "explanation": "Square perimeter = 44 cm. Circle circumference = 2 x 22/7 x r = 44. r = 44 x 7/44 = 7 cm."
    },
    "hi": {
      "question": "एक वर्ग का परिमाप एक वृत्त की परिधि के बराबर है। यदि वर्ग की भुजा 11 cm है, तो वृत्त की त्रिज्या ज्ञात करें। (π = 22/7 का उपयोग करें)",
      "options": [
        "5 cm",
        "6 cm",
        "7 cm",
        "8 cm"
      ],
      "explanation": "वर्ग का परिमाप = 44 cm। वृत्त की परिधि = 2 × 22/7 × r = 44। r = 44 × 7/44 = 7 cm।"
    }
  },
