    "en": {
      "question": "A boat can go 30 km downstream in 2 hours and return upstream in 3 hours. Find the speed of the stream.",
      "options": [
        "2 km/h",
        "2.5 km/h",
        "3 km/h",
        "5 km/h"
      ],
      "explanation": "Downstream speed = 30/2 = 15 km/h. Upstream speed = 30/3 = 10 km/h. Stream speed = (15-10)/2 = 2.5 km/h."
    },
    "hi": {
      "question": "एक नाव धारा के अनुकूल 30 km 2 घंटे में और धारा के प्रतिकूल 3 घंटे में जाती है। धारा की गति ज्ञात करें।",
      "options": [
        "2 km/h",
        "2.5 km/h",
        "3 km/h",
        "5 km/h"
      ],
      "explanation": "अनुकूल गति = 30/2 = 15 km/h। प्रतिकूल गति = 30/3 = 10 km/h। धारा की गति = (15-10)/2 = 2.5 km/h।"
    }
  },
