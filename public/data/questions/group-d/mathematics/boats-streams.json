    "sourceYear": 2024,
    "en": {
      "question": "A man can row at 6 km/h in still water. If the stream flows at 2 km/h, how long will he take to go 16 km upstream and return?",
      "options": [
        "5 hours",
        "6 hours",
        "7 hours",
        "8 hours"
      ],
      "explanation": "US speed = 6-2=4 km/h, DS speed = 6+2=8 km/h. US time = 16/4=4 hr, DS time=16/8=2 hr. Total = 6 hours."
    },
    "hi": {
      "question": "एक व्यक्ति शांत जल में 6 km/h की गति से नाव चला सकता है। यदि धारा 2 km/h बहती है, तो 16 km प्रतिकूल जाने और वापस आने में कितना समय लगेगा?",
      "options": [
        "5 घंटे",
        "6 घंटे",
        "7 घंटे",
        "8 घंटे"
      ],
      "explanation": "प्रतिकूल गति = 6-2=4 km/h, अनुकूल गति = 6+2=8 km/h। प्रतिकूल समय = 16/4=4 घंटे, अनुकूल समय=16/8=2 घंटे। कुल = 6 घंटे।"
    }
  },
