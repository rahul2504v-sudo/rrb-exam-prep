      "options": [
        "2 km/h",
        "3 km/h",
        "4 km/h",
        "5 km/h"
      ],
      "explanation": "अनुकूल गति = नाव की गति + धारा की गति। 15 = 12 + धारा। धारा = 3 km/h।"
    }
  },
  {
