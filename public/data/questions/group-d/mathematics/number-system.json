      "question": "What is the unit digit of 7^85?",
      "options": [
        "1",
        "3",
        "7",
        "9"
      ],
      "explanation": "Cycle of unit digits of 7^n: 7, 9, 3, 1 (cycle of 4). 85 mod 4 = 1, so unit digit = 7."
    },
    "hi": {
      "question": "7^85 का इकाई अंक क्या है?",
      "options": [
        "1",
        "3",
        "7",
        "9"
      ],
      "explanation": "7^n के इकाई अंक का चक्र: 7, 9, 3, 1 (4 का चक्र)। 85 mod 4 = 1, इसलिए इकाई अंक = 7।"
    }
  },
