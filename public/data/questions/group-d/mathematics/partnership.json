    "sourceYear": 2023,
    "en": {
      "question": "A started a business with Rs. 8000. After 6 months, B joined with Rs. 12000. At the end of the year, the profit was Rs. 7000. Find A's share.",
      "options": [
        "Rs. 3000",
        "Rs. 3500",
        "Rs. 4000",
        "Rs. 4500"
      ],
      "explanation": "A's capital x time = 8000x12 = 96000. B's = 12000x6 = 72000. Ratio = 96:72 = 4:3. A's share = 4/7 x 7000 = 4000."
    },
    "hi": {
      "question": "A ने Rs. 8000 से एक व्यवसाय शुरू किया। 6 माह बाद, B ने Rs. 12000 के साथ जुड़ा। वर्ष के अंत में लाभ Rs. 7000 था। A का हिस्सा ज्ञात करें।",
      "options": [
        "Rs. 3000",
        "Rs. 3500",
        "Rs. 4000",
        "Rs. 4500"
      ],
      "explanation": "A की पूंजी × समय = 8000×12 = 96000। B की = 12000×6 = 72000। अनुपात = 96:72 = 4:3। A का हिस्सा = 4/7 × 7000 = 4000।"
    }
  },
  {
    "id": "groupd-m-0005",
    "correctOption": "B",
    "difficulty": "medium",
    "sourceYear": 2024,
    "en": {
      "question": "A and B invest in the ratio 2 : 3. After 4 months, A withdraws half his capital. If the annual profit is Rs. 5200, find B's share.",
      "options": [
        "Rs. 3300",
        "Rs. 3600",
        "Rs. 3800",
        "Rs. 4200"
      ],
      "explanation": "A contribution: 2x for 4 months + x for 8 months = 16x. B: 3x for 12 months = 36x. Ratio A:B = 16:36 = 4:9. B share = 9/13 x 5200 = 3600."
    },
    "hi": {
      "question": "A और B 2 : 3 के अनुपात में निवेश करते हैं। 4 माह बाद, A अपनी पूंजी का आधा निकाल लेता है। यदि वार्षिक लाभ Rs. 5200 है, तो B का हिस्सा ज्ञात करें।",
      "options": [
        "Rs. 3300",
        "Rs. 3600",
        "Rs. 3800",
        "Rs. 4200"
      ],
      "explanation": "A का योगदान: 2x 4 माह + x 8 माह = 16x। B: 3x 12 माह = 36x। अनुपात A:B = 16:36 = 4:9। B का हिस्सा = 9/13 × 5200 = 3600।"
    }
  },
